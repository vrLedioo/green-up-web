# ─────────────────────────────────────────────────────────────────────────────
# Green Up — Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# Formspree form ID (server-side only — no NEXT_PUBLIC_ prefix intentional)
# The value is the hash after /f/ in your Formspree endpoint URL.
# Example: if your endpoint is https://formspree.io/f/xzdkjeje, the ID is xzdkjeje
FORMSPREE_ID=your_formspree_form_id_here

# ─── Optional: Future additions ───────────────────────────────────────────────
# If you add analytics, reCAPTCHA, or a CMS later, document the vars here.
# Never prefix server-only secrets with NEXT_PUBLIC_.
